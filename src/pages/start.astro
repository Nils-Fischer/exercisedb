---
// src/pages/index.astro
const title = "Next generation creative collaboration";
import Layout from "../layouts/Layout.astro";
---

<Layout title="ExerciseDB">
  <html lang="de" data-theme="emerald">
    <head>
      <meta charset="utf-8" />
      <link rel="icon" type="image/svg+xml" href="favicon.svg" />
      <meta name="viewport" content="width=device-width, initial-scale=1.0" />
      <title>{title}</title>
    </head>
    <body class="bg-gray-900 text-neutral-content">
      <main>
        <!-- Hero Section -->
        <div
          class="hero min-h-screen flex flex-col items-center justify-center text-center bg-gradient-to-r from-gray-700 via-gray-900 to-black"
        >
          <div class="max-w-2xl bg-gray-800 bg-opacity-90 p-8 rounded-lg shadow-lg">
            <h1 class="text-5xl font-bold text-white">Next generation creative collaboration.</h1>
            <p class="py-6 text-gray-300">
              Frame.io is one central hub that lets you share media, track feedback, and streamline your workflow so
              your team can work closely together from anywhere in the world.
            </p>
            <a
              class="btn btn-primary bg-blue-600 hover:bg-blue-800 text-white font-bold py-2 px-4 rounded-full transition duration-300"
            >
              Start Free Trial
            </a>
          </div>
        </div>
        <!-- Placeholder for Image or Video -->
        <div class="flex justify-center mt-10">
          <img
            src="/path/to/your/image-or-video-placeholder.jpg"
            alt="Placeholder"
            class="max-w-full h-auto rounded-lg shadow-lg"
          />
        </div>
      </main>
    </body>
  </html>
</Layout>
