---
import Layout from "../layouts/Layout.astro";
import WorkoutPlannerForm from "../components/WorkoutPlannerForm.svelte";
import { generateExercises } from "../constant";
import type { Exercise } from "../lib/types";

const exercises_file_path = "./src/data/exercises.json";
const exercises: Exercise[] = generateExercises(exercises_file_path);
---

<Layout title="Workout Planner">
  <WorkoutPlannerForm client:load exercises={exercises} />
</Layout>
