---
import Layout from "../layouts/Layout.astro";
---

<Layout Title="Register">
  <div class="flex flex-col gap-4 rounded-box bg-base-200 p-6 max-w-md rounded-md">
    <!-- Hier rounded-md hinzugefügt -->
    <h1 class="text-3xl font-bold self-center">Create an account</h1>

    <span class="self-center">
      Already have an account?
      <a href="/signin" class="link link-secondary">Log in</a>
    </span>

    <a class="btn btn-neutral rounded-md">
      <!-- Hier rounded-md hinzugefügt -->
      <i class="fa-brands fa-google text-primary"></i>
      Create with Google
    </a>

    <div class="divider my-0">OR</div>

    <label class="form-control">
      <div class="label">
        <span class="label-text">Email</span>
      </div>

      <input class="input input-bordered rounded-md" />
      <!-- Hier rounded-md hinzugefügt -->
    </label>

    <label class="form-control">
      <div class="label">
        <span class="label-text">Password</span>
      </div>

      <input type="password" class="input input-bordered rounded-md" />
      <!-- Hier rounded-md hinzugefügt -->
    </label>

    <label class="form-control">
      <div class="label">
        <span class="label-text">Confirm password</span>
      </div>

      <input type="password" class="input input-bordered rounded-md" />
      <!-- Hier rounded-md hinzugefügt -->
    </label>

    <div class="form-control">
      <label class="cursor-pointer label self-start gap-2">
        <input type="checkbox" class="checkbox rounded-md" />
        <!-- Hier rounded-md hinzugefügt -->
        <span class="label-text">
          I accept the
          <a class="link link-accent">Terms and Conditions</a>
        </span>
      </label>
    </div>

    <button class="btn btn-primary rounded-md">Create</button>
    <!-- Hier rounded-md hinzugefügt -->
  </div>
</Layout>
